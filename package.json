{
  "name": "gyro-governance",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "destinations": "node scripts/build-destinations.mjs && node scripts/generate-seo-files.mjs",
    "tours-cities": "node scripts/fetch-wegotrip-cities.mjs",
    "atlas": "node scripts/fetch-wegotrip-cities.mjs && bun run destinations",
    "sync-private-md": "node scripts/sync-private-markdown-gyroscope.mjs",
    "seo": "node scripts/generate-seo-files.mjs",
    "favicons": "node scripts/optimize-favicons.mjs",
    "build": "vite build && node scripts/copy-spa-fallback.mjs",
    "preview": "vite preview",
    "audit": "node scripts/site-audit.mjs",
    "check:routes": "node scripts/check-routes-http.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8",
    "vite-imagetools": "^10.0.0"
  }
}
